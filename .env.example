# Openhands provider
LLM_MODEL="anthropic/claude-sonnet-4-5-20250929"
LLM_API_KEY=
LLM_BASE_URL=

# Openhands settings
LLM_TIMEOUT="300"
LLM_TEMPERATURE="0.0"
LLM_TOP_P="1.0"
LLM_MAX_INPUT_TOKENS="131072"
LLM_MAX_OUTPUT_TOKENS="131072"
LLM_REASONING_EFFORT="high"
LLM_ENABLE_ENCRYPTED_REASONING="false"
LLM_PROMPT_CACHE_RETENTION="24h"
LLM_EXTENDED_THINKING_BUDGET="200000"
LLM_NUM_RETRIES="5"
LLM_USAGE_ID="agent"

# Openhands logging
LOG_LEVEL="INFO"
LOG_TO_FILE="true"
LOG_JSON="true"

# Laminar monitoring (optional — set LMNR_PROJECT_API_KEY to enable tracing)
# LMNR_BASE_URL defaults to http://localhost (local) or
# http://host.docker.internal (sandbox, set in Dockerfile).
# LMNR_BASE_URL=
LMNR_PROJECT_API_KEY=
LMNR_HTTP_PORT="8000"
